# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).
# For GitHub Actions, add these as repository Secrets instead (see README).

# --- SMS (required to actually receive texts) ---
# Get a key at https://textbelt.com  (use "textbelt_test" for a free no-op)
TEXTBELT_KEY=textbelt_test
ALERT_PHONE=+14044443292

# --- Ticket sources (optional; each source needs its own key) ---
# Free key: https://developer.ticketmaster.com
TICKETMASTER_API_KEY=
# Free key: https://platform.seatgeek.com  (client id)
SEATGEEK_CLIENT_ID=
# Partner token: https://developer.stubhub.com  (approval required)
STUBHUB_TOKEN=

# --- Optional override of the price threshold in config.yaml ---
# MAX_PRICE_PER_TICKET=350
